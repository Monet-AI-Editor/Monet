a(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">03  0:06–0:10</div><div style=\"position:absolute;top:24px;right:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">logo scales in</div><div style=\"display:flex;flex-direction:column;align-items:center;gap:12px\"><div style=\"display:flex;align-items:center;gap:14px\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 28 28\" fill=\"none\"><path d=\"M14 2L16.5 9.5L24 7L19 13L26 16.5L18.5 17.5L20 25L14 20L8 25L9.5 17.5L2 16.5L9 13L4 7L11.5 9.5L14 2Z\" fill=\"white\"/></svg><div style=\"font-size:36px;font-weight:700;color:#fff;letter-spacing:-.02em\">supermemoryfs</div></div><div style=\"font-size:18px;color:rgba(255,255,255,0.38)\">memory as a filesystem.</div></div></div>"},{"id":"ab-4-cmds","name":"04 — Three Commands","width":1280,"height":720,"x":4160,"y":80,"html":"<div style=\"width:1280px;height:720px;background:#000;display:flex;align-items:center;justify-content:center;position:relative;font-family:'Inter',sans-serif\"><div style=\"position:absolute;top:24px;left:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">04  0:10–0:14</div><div style=\"position:absolute;top:24px;right:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">terminal · command types live</div><div style=\"display:flex;flex-direction:column;align-items:center;gap:28px;width:100%\"><div style=\"background:#111;border:1px solid rgba(255,255,255,.08);border-radius:12px;width:760px;overflow:hidden\"><div style=\"display:flex;align-items:center;gap:7px;padding:14px 18px;border-bottom:1px solid rgba(255,255,255,.05)\"><div style=\"width:12px;height:12px;border-radius:50%;background:#FF5F57\"></div><div style=\"width:12px;height:12px;border-radius:50%;background:#FEBC2E\"></div><div style=\"width:12px;height:12px;border-radius:50%;background:#28C840\"></div></div><div style=\"padding:28px 36px\"><pre style=\"font-size:20px;white-space:pre;font-family:'JetBrains Mono',monospace\"><span style=\"color:rgba(255,255,255,0.38)\">$</span> curl -fsSL smfs.ai/install | sh</pre><pre style=\"font-size:20px;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:8px\"><span style=\"color:rgba(255,255,255,0.38)\">$</span> smfs login</pre><pre style=\"font-size:20px;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:8px\"><span style=\"color:rgba(255,255,255,0.38)\">$</span> smfs mount ~/memory</pre><pre style=\"font-size:20px;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:8px\"><span style=\"color:rgba(255,255,255,0.38)\">$</span> <span style=\"background:#369BFD;color:#000;padding:0 2px\">█</span></pre></div></div><div style=\"font-size:16px;color:rgba(255,255,255,0.38)\">that's it.</div></div></div>"},{"id":"ab-5-real","name":"05 — It's Real","width":1280,"height":720,"x":5520,"y":80,"html":"<div style=\"width:1280px;height:720px;background:#000;display:flex;align-items:center;justify-content:center;position:relative;font-family:'Inter',sans-serif\"><div style=\"position:absolute;top:24px;left:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">05  0:14–0:17</div><div style=\"position:absolute;top:24px;right:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">files appear one by one</div><div style=\"background:#111;border:1px solid rgba(255,255,255,.08);border-radius:12px;width:760px;overflow:hidden\"><div style=\"display:flex;align-items:center;gap:7px;padding:14px 18px;border-bottom:1px solid rgba(255,255,255,.05)\"><div style=\"width:12px;height:12px;border-radius:50%;background:#FF5F57\"></div><div style=\"width:12px;height:12px;border-radius:50%;background:#FEBC2E\"></div><div style=\"width:12px;height:12px;border-radius:50%;background:#28C840\"></div></div><div style=\"padding:28px 36px\"><pre style=\"font-size:20px;white-space:pre;font-family:'JetBrains Mono',monospace\"><span style=\"color:rgba(255,255,255,0.38)\">$</span> ls ~/memory</pre><pre style=\"font-size:20px;color:#369BFD;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:12px\">profile.md</pre><pre style=\"font-size:20px;color:#369BFD;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:4px\">notes/</pre><pre style=\"font-size:20px;color:#369BFD;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:4px\">projects/</pre><pre style=\"font-size:20px;color:#369BFD;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:4px\">meetings/</pre><pre style=\"font-size:20px;color:#369BFD;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:4px\">research/</pre><pre style=\"font-size:20px;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:12px\"><span style=\"color:rgba(255,255,255,0.38)\">$</span> <span style=\"background:#888;display:inline-block;width:12px;height:20px;vertical-align:middle\"></span></pre></div></div></div>"},{"id":"ab-6-wow","name":"06 — The Wow","width":1280,"height":720,"x":6880,"y":80,"html":"<div style=\"width:1280px;height:720px;background:#000;display:flex;align-items:center;justify-content:center;position:relative;font-family:'Inter',sans-serif\"><div style=\"position:absolute;top:24px;left:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">06  0:17–0:22</div><div style=\"position:absolute;top:24px;right:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">grep → semantic → results</div><div style=\"display:flex;flex-direction:column;align-items:center;gap:20px;width:100%\"><div style=\"background:#111;border:1px solid rgba(255,255,255,.08);border-radius:12px;width:860px;overflow:hidden\"><div style=\"display:flex;align-items:center;gap:7px;padding:14px 18px;border-bottom:1px solid rgba(255,255,255,.05)\"><div style=\"width:12px;height:12px;border-radius:50%;background:#FF5F57\"></div><div style=\"width:12px;height:12px;border-radius:50%;background:#FEBC2E\"></div><div style=\"width:12px;height:12px;border-radius:50%;background:#28C840\"></div></div><div style=\"padding:28px 36px\"><pre style=\"font-size:16px;color:rgba(255,255,255,0.38);white-space:pre;font-family:'JetBrains Mono',monospace\"><span style=\"color:rgba(255,255,255,.2)\">$</span> grep -r \"things I wanted to buy\" ~/memory</pre><pre style=\"font-size:14px;color:rgba(255,255,255,0.22);white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:6px;font-style:italic\"># 0 matches — normal grep finds nothing</pre><div style=\"display:flex;align-items:center;gap:12px;margin:14px 0\"><div style=\"flex:1;height:1px;background:rgba(255,255,255,.1)\"></div><div style=\"font-size:13px;color:#369BFD;font-family:'JetBrains Mono',monospace;letter-spacing:.04em\">smfs intercepts → semantic search</div><div style=\"flex:1;height:1px;background:rgba(255,255,255,.1)\"></div></div><pre style=\"font-size:15px;white-space:pre;font-family:'JetBrains Mono',monospace\"><span style=\"color:#36FDB5\">wishlist.md:</span>   Sony WH-1000XM5 headphones</pre><pre style=\"font-size:15px;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:6px\"><span style=\"color:#36FDB5\">shopping.md:</span>   standing desk for home office</pre><pre style=\"font-size:15px;white-space:pre;font-family:'JetBrains Mono',monospace;margin-top:6px\"><span style=\"color:#36FDB5\">notes.md:</span>      mechanic said I need new tires</pre></div></div><div style=\"font-size:15px;color:rgba(255,255,255,0.38)\">you typed grep. supermemoryfs ran a vector search. grep doesn't know.</div></div></div>"},{"id":"ab-7-kicker","name":"07 — The Kicker","width":1280,"height":720,"x":8240,"y":80,"html":"<div style=\"width:1280px;height:720px;background:linear-gradient(180deg,#000 0%,#0d0dcc 55%,#1a1aff 100%);display:flex;align-items:center;justify-content:center;position:relative;font-family:'Inter',sans-serif\"><div style=\"position:absolute;top:24px;left:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">07  0:22–0:26</div><div style=\"position:absolute;top:24px;right:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">lines drop in · dissolve</div><div style=\"display:flex;flex-direction:column;gap:8px;align-items:center;text-align:center\"><div style=\"font-size:52px;font-weight:800;color:#fff;letter-spacing:-.03em;line-height:1.15\">No SDK.</div><div style=\"font-size:52px;font-weight:800;color:#fff;letter-spacing:-.03em;line-height:1.15\">No API calls.</div><div style=\"font-size:52px;font-weight:800;color:#fff;letter-spacing:-.03em;line-height:1.15\">Just files.</div></div></div>"},{"id":"ab-8-cta","name":"08 — CTA","width":1280,"height":720,"x":9600,"y":80,"html":"<div style=\"width:1280px;height:720px;background:linear-gradient(180deg,#000 0%,#0d0dcc 55%,#1a1aff 100%);display:flex;align-items:center;justify-content:center;position:relative;font-family:'Inter',sans-serif\"><div style=\"position:absolute;top:24px;left:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">08  0:26–0:30</div><div style=\"position:absolute;top:24px;right:32px;font-size:11px;color:rgba(255,255,255,0.22);font-family:'JetBrains Mono',monospace\">logo fades · freeze</div><div style=\"display:flex;flex-direction:column;align-items:center;gap:12px\"><div style=\"display:flex;align-items:center;gap:14px\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 28 28\" fill=\"none\"><path d=\"M14 2L16.5 9.5L24 7L19 13L26 16.5L18.5 17.5L20 25L14 20L8 25L9.5 17.5L2 16.5L9 13L4 7L11.5 9.5L14 2Z\" fill=\"white\"/></svg><div style=\"font-size:36px;font-weight:700;color:#fff;letter-spacing:-.02em\">supermemoryfs</div></div><div style=\"font-size:16px;color:rgba(255,255,255,0.38);letter-spacing:.04em\">smfs.ai</div></div></div>"}]
